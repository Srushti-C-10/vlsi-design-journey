module tb_demux_1to4;
reg i;
reg s0,s1;
wire y0,y1,y2,y3;

demux_1to4 dut(.i(i),.s0(s0),.s1(s1),.y0(y0),.y1(y1),.y2(y2),.y3(y3));
initial begin
i=1;
{s1,s0}=2'b00;#10;
{s1,s0}=2'b01;#10;
{s1,s0}=2'b10;#10;
{s1,s0}=2'b11;#10;

i=0;
{s1,s0}=2'b00;#10;
{s1,s0}=2'b01;#10;
{s1,s0}=2'b10;#10;
{s1,s0}=2'b11;#10;
$finish;
end
initial
$monitor("Input i=%b,s1=%b,s0=%b => Output y0=%b,y1=%b,y2=%b,y3=%b",i,s1,s0,y0,y1,y2,y3);
endmodule
