`timescale 1ns/1ps

module mod8_counter_tb;

  reg clk;
  reg rst;
  wire [2:0] count;

  mod8_counter uut (
    .clk(clk),
    .rst(rst),
    .count(count)
  );

  always #5 clk = ~clk;

  initial begin
    clk = 0;
    rst = 1;
    #10;
    rst = 0;
    #100;
    rst = 1;
    #10;
    rst = 0;
    #50;
    $finish;
  end

  initial begin
    $monitor("Time=%0t rst=%b count=%b", $time, rst, count);
  end

endmodule
