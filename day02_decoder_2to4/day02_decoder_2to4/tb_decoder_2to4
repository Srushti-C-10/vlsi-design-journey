module tb_decoder;
reg a;
reg b;
wire y0;
wire y1;
wire y2;
wire y3;

integer i;

dec2_4 dut(.a(a),.b(b),.y0(y0),.y1(y1),.y2(y2),.y3(y3));
initial
begin
for(i=0;i<4;i=i+1)
begin
{a,b}=i;
#10;
end
end
initial
$monitor("Input a=%b,b=%b => output y0=%b,y1=%b,y2=%b,y3=%b",a,b,y0,y1,y2,y3);
initial #50 $finish;
endmodule
