module tb_encoder_4to2;

reg i0,i1,i2,i3;
wire y0,y1;

encoder_4to2 dut(i0,i1,i2,i3,y0,y1);

initial
begin
    {i3,i2,i1,i0} = 4'b0001; #10;
    {i3,i2,i1,i0} = 4'b0010; #10;
    {i3,i2,i1,i0} = 4'b0100; #10;
    {i3,i2,i1,i0} = 4'b1000; #10;
    {i3,i2,i1,i0} = 4'b1010; #10;

    $finish;
end

endmodule
