module tb_dff;

reg clk, rst, d;
wire q;

dff uut (
  .clk(clk),
  .rst(rst),
  .d(d),
  .q(q)
);

always #5 clk = ~clk;

initial begin
  clk = 0;
  rst = 1;
  d = 0;

  #10 rst = 0;

  #10 d = 1;
  #10 d = 0;
  #10 d = 1;

  #10 rst = 1;
  #10 rst = 0;

  #20 $finish;
end

initial begin
  $monitor("Time=%0t rst=%b d=%b q=%b", $time, rst, d, q);
end

endmodule
